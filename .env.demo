# Dryad Demo Mode Environment
# Copy to .env or source alongside .env to run the demo:
#   cp .env .env.backup && cat .env.demo >> .env && elizaos start

DEMO_MODE=true

# Use an existing EVM key (testnet only — no real funds at risk)
# Generate one with: node -e "console.log('0x' + require('crypto').randomBytes(32).toString('hex'))"
# Then fund it with Base Sepolia testnet ETH from https://www.alchemy.com/faucets/base-sepolia
# EVM_PRIVATE_KEY=0x...

# Optional: override testnet contract addresses if you deploy your own
# DEMO_USDC_ADDRESS=0x036CbD53842c5426634e7929541eC2318f3dCF7e
# DEMO_WSTETH_ADDRESS=0x...
# DEMO_DIEM_ADDRESS=0x...
# DEMO_MILESTONES_ADDRESS=0x...
# DEMO_RPC_URL=https://sepolia.base.org

# Venice AI still needed for the LLM (vision mocked in demo mode)
# VENICE_API_KEY=...
